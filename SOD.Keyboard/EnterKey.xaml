<UserControl
    x:Class="SOD.Keyboard.EnterKey"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SOD.Keyboard"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Button
        Width="142"
        Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:Keyboard}, Mode=FindAncestor}, Path=Enter}"
        IsDefault="True"
        Style="{StaticResource KeyboardButtonTool}">
        <materialDesign:PackIcon
            Width="30"
            Height="30"
            Kind="KeyboardReturn" />
    </Button>
</UserControl>
