<Report ScriptLanguage="CSharp" ReportInfo.Created="10/21/2020 16:03:35" ReportInfo.Modified="11/14/2024 09:03:16" ReportInfo.CreatorVersion="2024.2.14.0">
  <ScriptText>using System;
using System.Collections;
using System.Collections.Generic;
using System.ComponentModel;
using System.Windows.Forms;
using System.Drawing;
using System.Data;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;

namespace FastReport
{
  public class ReportScript
  {

    private void Data1_BeforePrint(object sender, EventArgs e)
    {
      // get a reference to the data source
      DataSourceBase ds = Report.GetDataSource(&quot;MainData.Tests.Posts.Registrations&quot;);
      // initialize it
      ds.Init();
      // enum all rows
      while (ds.HasMoreRows)
      {
        if ((string)Report.GetColumnValue(&quot;MainData.Tests.Posts.Registrations.StartPressure&quot;)==String.Empty)
        {
          StrengthTestData.Visible=false;
          ResultTestData.Visible=false;
        }
        else
        {
          StrengthTestData.Visible=true;
          ResultTestData.Visible=true;
        }
        
        if ((String)Report.GetColumnValue(&quot;MainData.Tests.Posts.Registrations.LeakageTest.Leakage&quot;)==String.Empty)
        {
          LeakageTestData.Visible=false;
          ResultTestData.Visible=false;
        }
        else
        {
          LeakageTestData.Visible=true;
          ResultTestData.Visible=true;
        }
        
        if (((String)Report.GetColumnValue(&quot;MainData.Tests.Posts.Registrations.FuncionalTest.OpenPressure&quot;))==String.Empty)
        {
          FuncionalTestData.Visible=false;
        }
        else
        {
           FuncionalTestData.Visible=true;
        }  
        ds.Next();
      }
    }
  }
}
</ScriptText>
