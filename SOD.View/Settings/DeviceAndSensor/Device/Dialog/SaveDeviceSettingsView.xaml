<UserControl
    x:Class="SOD.View.Settings.DeviceAndSensor.Device.Dialog.SaveDeviceSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:SOD.View.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lc="clr-namespace:SOD.LocalizationService;assembly=SOD.LocalizationService"
    xmlns:local="clr-namespace:SOD.View.Settings.DeviceAndSensor.Device.Dialog"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="600"
    Height="400"
    mc:Ignorable="d">
    <controls:YesNoDialog
        NoCommand="{Binding No}"
        NoText="{lc:Localization Settings.DeviceAndSensor.Device.No}"
        YesCommand="{Binding Yes}"
        YesText="{lc:Localization Settings.DeviceAndSensor.Device.Yes}">
        <controls:YesNoDialog.MessageContent>
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                Text="{lc:Localization Settings.DeviceAndSensor.Device.SaveSettings}" />
        </controls:YesNoDialog.MessageContent>
    </controls:YesNoDialog>
</UserControl>
