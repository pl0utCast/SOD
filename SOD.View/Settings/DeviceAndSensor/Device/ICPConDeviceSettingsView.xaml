<UserControl
    x:Class="SOD.View.Settings.DeviceAndSensor.Device.ICPConDeviceSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:SOD.View.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:deviceVM="clr-namespace:SOD.ViewModels.Settings.DeviceAndSensor.Device;assembly=SOD.ViewModels"
    xmlns:lc="clr-namespace:SOD.LocalizationService;assembly=SOD.LocalizationService"
    xmlns:local="clr-namespace:SOD.View.Settings.DeviceAndSensor.Device"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <controls:BackButton />
        <controls:SaveButton Margin="70,0,0,0" HorizontalAlignment="Left" />
        <controls:CustomScrollViewer Grid.Row="1">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        Margin="5"
                        materialDesign:HintAssist.Hint="{lc:Localization Settings.DeviceAndSensor.Device.Name}"
                        FontSize="24"
                        Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                        Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                    <Button 
                        Grid.Column="1"
                        Margin="5,5,5,0"
                        FontSize="18"
                        Height="60"
                        Command="{Binding OpenWebDevice}"
                        Style="{StaticResource MaterialDesignFlatButton}" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="50"
                                Height="50"
                                HorizontalAlignment="Center"
                                Kind="SearchWeb" />
                            <TextBlock 
                                Foreground="#FF3F51B5" 
                                Text="{lc:Localization Video.OpenWebCamera}" 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60*" />
                        <ColumnDefinition Width="20*" />
                        <ColumnDefinition Width="20*" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        Margin="5"
                        materialDesign:HintAssist.Hint="{lc:Localization Settings.DeviceAndSensor.Device.IpAddress}"
                        FontSize="24"
                        Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                        Text="{Binding HostOrIp, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox
                        Grid.Column="1"
                        Margin="5"
                        materialDesign:HintAssist.Hint="{lc:Localization Settings.DeviceAndSensor.Device.Port}"
                        FontSize="24"
                        Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                        Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox
                        Grid.Column="2"
                        Margin="5"
                        materialDesign:HintAssist.Hint="Slave Id"
                        FontSize="24"
                        Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                        Text="{Binding SlaveId, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <TextBlock
                    Grid.Row="2"
                    Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                    Text="{lc:Localization Settings.DeviceAndSensor.IcpDevice.InputRegisters}" />
                <StackPanel
                    Grid.Row="3"
                    Margin="10"
                    Orientation="Horizontal">
                    <Button
                        Height="50"
                        Command="{Binding AddRegister}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="34"
                                Height="34"
                                VerticalAlignment="Center"
                                Kind="Add" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="20"
                                Text="{lc:Localization Settings.DeviceAndSensor.IcpDevice.Add}" />
                        </StackPanel>
                    </Button>
                    <Button
                        Height="50"
                        Margin="10,0,0,0"
                        Command="{Binding Edit}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="34"
                                Height="34"
                                VerticalAlignment="Center"
                                Kind="Edit" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="20"
                                Text="{lc:Localization Settings.DeviceAndSensor.IcpDevice.Edit}" />
                        </StackPanel>
                    </Button>
                    <Button
                        Height="50"
                        Margin="10,0,0,0"
                        Command="{Binding Delete}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="34"
                                Height="34"
                                VerticalAlignment="Center"
                                Kind="Delete" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="20"
                                Text="{lc:Localization Settings.DeviceAndSensor.IcpDevice.Delete}" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <DataGrid
                    Grid.Row="4"
                    MinHeight="300"
                    Margin="5"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    ItemsSource="{Binding Registers}"
                    SelectedValue="{Binding SelectedRegister}"
                    SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding Id}" Header="{lc:Localization Settings.DeviceAndSensor.IcpDevice.ModbusId}" />
                        <DataGridTextColumn Binding="{Binding DataType}" Header="{lc:Localization Settings.DeviceAndSensor.IcpDevice.DataType}" />
                        <DataGridTextColumn Binding="{Binding Value}" Header="{lc:Localization Settings.DeviceAndSensor.IcpDevice.Value}" />
                        <DataGridTextColumn Binding="{Binding Description}" Header="{lc:Localization Settings.DeviceAndSensor.IcpDevice.Description}" />
                    </DataGrid.Columns>
                </DataGrid>
                <TextBlock
                    Grid.Row="5"
                    Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                    Text="{lc:Localization Settings.DeviceAndSensor.IcpDevice.CoilsRegisters}" />
                <ItemsControl
                    Grid.Row="6"
                    ItemsSource="{Binding ReadWriteRegisters}">
                    <ItemsControl.Resources>
                        <DataTemplate DataType="{x:Type deviceVM:ModbusReadWriteRegisterViewModel}">
                            <local:ModbusReadWriteRegisterView Margin="5" />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type deviceVM:ModbusReadWriteBoolRegisterViewModel}">
                            <local:ModbusReadWriteBoolRegisterView Margin="5" />
                        </DataTemplate>
                    </ItemsControl.Resources>
                </ItemsControl>
                <controls:AddButton
                    Grid.Row="7"
                    Margin="0,0,60,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom" />
                <TextBlock
                    Grid.Row="8"
                    Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                    Text="{lc:Localization Settings.DeviceAndSensor.IcpDevice.HoldingRegisters}" />
                <ItemsControl
                    Grid.Row="9"
                    ItemsSource="{Binding ReadHoldingRegisters}">
                    <ItemsControl.Resources>
                        <DataTemplate DataType="{x:Type deviceVM:ModbusReadWriteRegisterViewModel}">
                            <local:ModbusReadWriteRegisterView Margin="5" />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type deviceVM:ModbusReadWriteBoolRegisterViewModel}">
                            <local:ModbusReadWriteBoolRegisterView Margin="5" />
                        </DataTemplate>
                    </ItemsControl.Resources>
                </ItemsControl>
                <Button
                    Grid.Row="10"
                    Command="{Binding AddHoldingRegister}"
                    Margin="0,0,60,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Style="{StaticResource MaterialDesignFloatingActionButton}">
                    <materialDesign:PackIcon
                        Width="24"
                        Height="24"
                        Kind="Add" />
                </Button>
            </Grid>
        </controls:CustomScrollViewer>
    </Grid>
</UserControl>
