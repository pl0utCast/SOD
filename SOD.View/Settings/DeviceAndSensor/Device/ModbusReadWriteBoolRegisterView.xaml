<UserControl
    x:Class="SOD.View.Settings.DeviceAndSensor.Device.ModbusReadWriteBoolRegisterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:SOD.View.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SOD.View.Settings.DeviceAndSensor.Device"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50" />
            <ColumnDefinition Width="100" />
            <ColumnDefinition />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>
        <StackPanel>
            <TextBlock
                HorizontalAlignment="Center"
                FontSize="22"
                Text="Id" />
            <TextBlock
                HorizontalAlignment="Center"
                FontSize="22"
                Text="{Binding Id}" />
        </StackPanel>
        <ToggleButton
            Grid.Column="1"
            Width="60"
            Height="35"
            IsChecked="{Binding Value}" />
        <TextBlock
            Grid.Column="2"
            VerticalAlignment="Center"
            FontSize="24"
            Text="{Binding Description}" />
        <controls:DeleteFlatButton Grid.Column="3" />
    </Grid>
</UserControl>
