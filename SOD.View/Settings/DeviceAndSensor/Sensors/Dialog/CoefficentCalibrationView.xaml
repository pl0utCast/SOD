<UserControl
    x:Class="SOD.View.Settings.DeviceAndSensor.Sensors.Dialog.CoefficentCalibrationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:SOD.View.Controls"
    xmlns:controlsVM="clr-namespace:SOD.ViewModels.Controls;assembly=SOD.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lc="clr-namespace:SOD.LocalizationService;assembly=SOD.LocalizationService"
    xmlns:local="clr-namespace:SOD.View.Settings.DeviceAndSensor.Sensors.Dialog"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <controls:YesNoDialog
        HorizontalAlignment="Center"
        NoCommand="{Binding No}"
        NoText="{lc:Localization Settings.DeviceAndSensor.Sensor.Cancel}"
        YesCommand="{Binding Save}"
        YesText="{lc:Localization Settings.DeviceAndSensor.Sensor.Save}">
        <controls:YesNoDialog.MessageContent>
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel
                    Grid.Row="0"
                    Margin="5,0,0,30"
                    Orientation="Horizontal">
                    <TextBlock Style="{StaticResource MaterialDesignHeadline5TextBlock}" Text="{lc:Localization Settings.DeviceAndSensor.Sensor.CurrentCode}" />
                    <TextBlock Style="{StaticResource MaterialDesignHeadline5TextBlock}" Text="{Binding Code}" />
                </StackPanel>

                <controls:CustomScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                        <ItemsControl ItemsSource="{Binding Coefficients}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <TextBlock
                                            Margin="0,10,0,7"
                                            materialDesign:HintAssist.Hint="Id"
                                            Opacity="0.7"
                                            FontSize="24"
                                            Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                                            Text="{Binding Id}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    
                        <ItemsControl ItemsSource="{Binding InitialVal}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type controlsVM:UnitValueViewModel}">
                                    <controls:UnitValueView 
                                        FieldName="{lc:Localization Settings.DeviceAndSensor.Sensor.Weight}"
                                        FontSize="24"
                                        MinWidth="80"
                                        Margin="30,0,20,10"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding Coefficients}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <TextBox
                                            materialDesign:HintAssist.Hint="{lc:Localization Settings.DeviceAndSensor.Sensor.Code}"
                                            MinWidth="80"
                                            FontSize="24"
                                            Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                            Text="{Binding SavedCode}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding Buttons}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button 
                                        Margin="5,0,20,5"
                                        Height="50"
                                        Width="100"
                                        Content="{lc:Localization Settings.DeviceAndSensor.Sensor.SetCode}"
                                        Command="{Binding}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl ItemsSource="{Binding DeleteButtons}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button
                                        Height="55"
                                        Command="{Binding}"
                                        Style="{StaticResource MaterialDesignFlatButton}">
                                        <materialDesign:PackIcon
                                            Width="40"
                                            Height="40"
                                            Kind="Delete" />
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </controls:CustomScrollViewer>

                <StackPanel Grid.Row="2">
                    <Button
                        Height="60"
                        Command="{Binding Add}"
                        Style="{StaticResource MaterialDesignFlatButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="40"
                                Height="40"
                                Kind="AddCircle" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="24"
                                Text="{lc:Localization Settings.DeviceAndSensor.Sensor.Add}" />
                        </StackPanel>

                    </Button>
                </StackPanel>
            </Grid>
        </controls:YesNoDialog.MessageContent>
    </controls:YesNoDialog>
</UserControl>
