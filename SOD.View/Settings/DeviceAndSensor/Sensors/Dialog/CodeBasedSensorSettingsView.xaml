<UserControl
    x:Class="SOD.View.Settings.DeviceAndSensor.Sensors.Dialog.CodeBasedSensorSettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:SOD.View.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lc="clr-namespace:SOD.LocalizationService;assembly=SOD.LocalizationService"
    xmlns:local="clr-namespace:SOD.View.Settings.DeviceAndSensor.Sensors.Dialog"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <controls:YesNoDialog
        HorizontalAlignment="Center"
        NoCommand="{Binding No}"
        NoText="{lc:Localization Settings.DeviceAndSensor.Sensor.Cancel}"
        YesCommand="{Binding Yes}"
        YesText="{lc:Localization Settings.DeviceAndSensor.Sensor.Save}">
        <controls:YesNoDialog.MessageContent>
            <StackPanel Margin="10">
                <StackPanel
                    Grid.Row="0"
                    Margin="5 0 0 0"
                    Orientation="Horizontal">
                    <TextBlock Style="{StaticResource MaterialDesignHeadline5TextBlock}" Text="{lc:Localization Settings.DeviceAndSensor.Sensor.CurrentValue}" />
                    <TextBlock Style="{StaticResource MaterialDesignHeadline5TextBlock}" Text="{Binding Value}" />
                </StackPanel>
                <StackPanel
                    Grid.Row="0"
                    Margin="5 0 0 0"
                    Orientation="Horizontal">
                    <TextBlock Style="{StaticResource MaterialDesignHeadline5TextBlock}" Text="{lc:Localization Settings.DeviceAndSensor.Sensor.CurrentCode}" />
                    <TextBlock Style="{StaticResource MaterialDesignHeadline5TextBlock}" Text="{Binding Code}" />
                </StackPanel>
                <TextBlock FontSize="16" Text="{Binding Id, StringFormat=Id: {0}}" />
                <TextBox
                    Grid.Row="1"
                    Margin="5 10 0 0"
                    materialDesign:HintAssist.Hint="{lc:Localization Settings.DeviceAndSensor.Sensor.Name}"
                    FontSize="22"
                    Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                    Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox
                    Grid.Row="2"
                    Margin="5 10 0 0"
                    materialDesign:HintAssist.Hint="{lc:Localization Settings.DeviceAndSensor.Sensor.ChannelNumber}"
                    FontSize="22"
                    Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                    Text="{Binding ChannelId, UpdateSourceTrigger=PropertyChanged}" />
                <Grid>
                    <TextBox
                        Grid.Row="2"
                        Margin="5 10 0 0"
                        HorizontalAlignment="Stretch"
                        materialDesign:HintAssist.Hint="{lc:Localization Settings.DeviceAndSensor.Sensor.MinCode}"
                        FontSize="22"
                        Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                        Text="{Binding MinCode, UpdateSourceTrigger=PropertyChanged}" />
                    <Button
                        Height="50"
                        HorizontalAlignment="Right"
                        Command="{Binding SetMinCode}"
                        Content="{lc:Localization Settings.DeviceAndSensor.Sensor.SetCode}"
                        FontSize="22" />
                </Grid>
                <Grid>
                    <TextBox
                        Grid.Row="2"
                        Margin="5 10 0 0"
                        HorizontalAlignment="Stretch"
                        materialDesign:HintAssist.Hint="{lc:Localization Settings.DeviceAndSensor.Sensor.MaxCode}"
                        FontSize="22"
                        Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                        Text="{Binding MaxCode, UpdateSourceTrigger=PropertyChanged}" />
                    <Button
                        Height="50"
                        HorizontalAlignment="Right"
                        Command="{Binding SetMaxCode}"
                        Content="{lc:Localization Settings.DeviceAndSensor.Sensor.SetCode}"
                        FontSize="22" />
                </Grid>
                <controls:UnitValueView
                    Margin="5 10 0 0"
                    FontSize="22"
                    DataContext="{Binding MinValue}"
                    FieldName="{lc:Localization Settings.DeviceAndSensor.Sensor.MinValue}" />
                <controls:UnitValueView
                    Margin="5 10 0 0"
                    FontSize="22"
                    DataContext="{Binding MaxValue}"
                    FieldName="{lc:Localization Settings.DeviceAndSensor.Sensor.MaxValue}" />
                <TextBox
                    Margin="5 10 0 0"
                    materialDesign:HintAssist.Hint="{lc:Localization Settings.DeviceAndSensor.Sensor.Accaury}"
                    FontSize="22"
                    Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                    Text="{Binding Accaury, UpdateSourceTrigger=PropertyChanged}" />
                <TextBox
                    Margin="5 10 0 0"
                    materialDesign:HintAssist.Hint="{lc:Localization Settings.DeviceAndSensor.Sensor.FilterCoef}"
                    FontSize="22"
                    Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                    Text="{Binding FilterCoef, UpdateSourceTrigger=PropertyChanged}" />
                <ComboBox
                    Margin="5 10 0 0"
                    materialDesign:HintAssist.Hint="{lc:Localization Settings.DeviceAndSensor.Sensor.UnitType}"
                    FontSize="22"
                    ItemsSource="{Binding UnitTypes}"
                    SelectedValue="{Binding UnitType}"
                    Style="{StaticResource MaterialDesignFloatingHintComboBox}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontSize="22" Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </controls:YesNoDialog.MessageContent>
    </controls:YesNoDialog>
</UserControl>
