<UserControl x:Class="SOD.View.Settings.Bench.SODBench.SodBenchSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SOD.View.Controls"
             xmlns:converters="clr-namespace:SOD.View.Converters"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SOD.View.Settings.Bench.SODBench"
             xmlns:lc="clr-namespace:SOD.LocalizationService;assembly=SOD.LocalizationService"
             xmlns:userService="clr-namespace:SOD.UserService;assembly=SOD.UserService"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:TranslatePrefixConverter x:Key="TranslatePrefixConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <StackPanel
            Grid.Row="0"
            userService:Security.Role="Technologist"
            Margin="0,5"
            Orientation="Horizontal">
            <ToggleButton IsChecked="{Binding AutoRange}" />
            <TextBlock
                VerticalAlignment="Center"
                FontSize="24"
                Text="{lc:Localization Settings.Bench.TestBenchSettingsView.UseAutoRange}" />
        </StackPanel>
        <StackPanel 
            Grid.Row="1"
            Visibility="{Binding ItemFromUser, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Margin="0,5" Orientation="Horizontal">
                <ToggleButton IsChecked="{Binding IsEnableGasTemperatureSensor}" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="24"
                    Text="{lc:Localization Settings.Bench.SodBenchSettingsView.UseTempSensorAir}" />
            </StackPanel>
            <ComboBox
                DisplayMemberPath="Name"
                FontSize="24"
                ItemsSource="{Binding TemperatureSensors}"
                SelectedValue="{Binding SelectedGasTemperatureSensor}" />
            <StackPanel Margin="0,5" Orientation="Horizontal">
                <ToggleButton IsChecked="{Binding IsEnableLiquidTemperatureSensor}" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="24"
                    Text="{lc:Localization Settings.Bench.SodBenchSettingsView.UseTempSensorWater}" />
            </StackPanel>
            <ComboBox
                DisplayMemberPath="Name"
                FontSize="24"
                ItemsSource="{Binding TemperatureSensors}"
                SelectedValue="{Binding SelectedLiquidTemperatureSensor}"/>

        </StackPanel>
        <StackPanel Grid.Row="2" Margin="0,5" Orientation="Horizontal">
            <ToggleButton 
                IsChecked="{Binding ManualLocation}"
                x:Name="check"/>
            <TextBlock
                VerticalAlignment="Center"
                FontSize="24"
                Text="{lc:Localization Settings.Bench.SodBenchSettingsView.ManualLocation}"/>
        </StackPanel>
        <TextBox 
            Grid.Row="3"
            IsEnabled="{Binding ManualLocation}"
            materialDesign:HintAssist.Hint="{lc:Localization Settings.Bench.SodBenchSettingsView.ReportTemplate}"
            FontSize="24">
            <TextBox.Style>
                <Style
                    TargetType="TextBox"
                    BasedOn="{StaticResource MaterialDesignFloatingHintTextBox}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ElementName=check,Path=IsChecked}" Value="False">
                            <Setter Property="Text" Value="{Binding ReportPathChanged}"></Setter>
                            <Setter Property="IsReadOnly" Value="False"></Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ElementName=check,Path=IsChecked}" Value="True">
                            <Setter Property="Text" Value="{Binding ReportPath}"></Setter>
                            <Setter Property="IsReadOnly" Value="True"></Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBox.Style>
        </TextBox>

        <Button
            x:Name="btnSelectReportPath"
            IsEnabled="{Binding ManualLocation}"
            Grid.Row="3"
            Height="50"
            HorizontalAlignment="Right"
            Content="{lc:Localization Settings.Bench.SodBenchSettingsView.Select}" />

        <materialDesign:Card 
            Grid.Row="4" 
            Margin="0,20,10,10"
            Visibility="{Binding ItemFromUser, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <materialDesign:ColorZone Padding="5" Mode="Standard">
                    <TextBlock
                        Grid.Row="2"
                        Margin="0,10,0,10"
                        FontSize="24"
                        Text="{lc:Localization Settings.Bench.SodBenchSettingsView.UsedSensors}" />
                </materialDesign:ColorZone>
                <ItemsControl
                    Grid.Row="1"
                    Margin="0,5,0,0"
                    ItemsSource="{Binding Sensors}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Grid.Row="1" Columns="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox materialDesign:CheckBoxAssist.CheckBoxSize="32" IsChecked="{Binding IsEnable}">
                                <TextBlock FontSize="24" Text="{Binding Name}" />
                            </CheckBox>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card 
            Grid.Row="5" 
            Margin="0,0,10,10"
            Visibility="{Binding ItemFromTehnologist, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <materialDesign:ColorZone Padding="5" Mode="Standard">
                    <TextBlock
                        Grid.Row="2"
                        Margin="0,10,0,10"
                        FontSize="24"
                        Text="{lc:Localization Testing.SODBench.TestParameters.Pressure}" />
                </materialDesign:ColorZone>
                <StackPanel Grid.Row="1">
                    <ListBox ItemsSource="{Binding PressureUnits}" SelectedValue="{Binding SelectedPressureUnit}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox
                                    Content="{Binding Name}"
                                    FontSize="20"
                                    IsChecked="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListBoxItem}, Path=IsSelected}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card 
            Grid.Row="6" 
            Margin="0,20,10,10"
            Visibility="{Binding ItemFromTehnologist, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <materialDesign:ColorZone Padding="5" Mode="Standard">
                    <TextBlock
                        Grid.Row="2"
                        Margin="0,10,0,10"
                        FontSize="24"
                        Text="{lc:Localization Settings.Bench.SodBenchSettingsView.SensorsName}" />
                </materialDesign:ColorZone>
                <ItemsControl
                    Grid.Row="1"
                    Margin="0,5,0,0"
                    ItemsSource="{Binding ChangeSensorsName}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Grid.Row="1" Columns="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBox FontSize="24" Margin="5" Text="{Binding Name}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card
            Grid.Row="7"
            Margin="0,10,10,10"
            DataContext="{Binding Parameters}"
            Visibility="{Binding ItemFromTehnologist, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <materialDesign:ColorZone Padding="5" Mode="Standard">
                    <Grid>
                        <TextBlock
                            VerticalAlignment="Center"
                            Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                            Text="{lc:Localization Settings.Bench.SodBenchSettingsView.Parameters}" />
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <controls:EditFlatButton />
                            <controls:DeleteFlatButton />
                        </StackPanel>
                    </Grid>
                </materialDesign:ColorZone>
                <Grid Grid.Row="1">
                    <ListBox
                        MinHeight="140"
                        ItemsSource="{Binding Parameters}"
                        ScrollViewer.VerticalScrollBarVisibility="Hidden"
                        SelectedValue="{Binding Parameter}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock FontSize="20" >
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource TranslatePrefixConverter}">
                                            <Binding Path="Alias"/>
                                            <Binding Path="Name"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <controls:AddButton
                        Margin="0,0,54,28"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom" />
                </Grid>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card 
            Grid.Row="8" 
            Margin="0,10,10,10"
            Visibility="{Binding ItemFromUser, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <materialDesign:ColorZone Padding="5" Mode="Standard">
                    <TextBlock
                        Margin="0,10,0,10"
                        FontSize="24"
                        Text="{lc:Localization Settings.DeviceAndSensor.Devices}" />
                </materialDesign:ColorZone>
                <ItemsControl
                    Grid.Row="1"
                    Margin="5,5,0,0"
                    ItemsSource="{Binding DevicesUnits}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox 
                                Margin="0,4,0,0"
                                materialDesign:CheckBoxAssist.CheckBoxSize="32" 
                                IsChecked="{Binding IsEnable}">
                                <TextBlock FontSize="24" Text="{Binding Name}" />
                            </CheckBox>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
