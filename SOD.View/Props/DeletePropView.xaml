<UserControl x:Class="SOD.View.Props.DeletePropView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SOD.View.Controls"
             xmlns:lc="clr-namespace:SOD.LocalizationService;assembly=SOD.LocalizationService"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SOD.View.Props"
             mc:Ignorable="d" >
    <controls:YesNoDialog
        Width="530"
        Height="200"
        NoCommand="{Binding Cancel}"
        NoText="{lc:Localization Props.DeletePropView.No}"
        YesCommand="{Binding Delete}"
        YesText="{lc:Localization Props.DeletePropView.Yes}">
        <controls:YesNoDialog.MessageContent>
            <TextBlock
            Margin="10"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="24"
            Text="{lc:Localization Props.DeletePropView.CanDelete}" />
        </controls:YesNoDialog.MessageContent>
    </controls:YesNoDialog>
</UserControl>
