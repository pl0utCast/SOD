                <ResourceDictionary Source="pack://application:,,,/SOD.View;component/Styles/Icons.xaml" />
                <ResourceDictionary Source="pack://application:,,,/SOD.View;component/Styles/Keyboard.xaml" />
                <ResourceDictionary Source="pack://application:,,,/SOD.View;component/Styles/BorderlessButton.xaml" />-->
            </ResourceDictionary.MergedDictionaries>
