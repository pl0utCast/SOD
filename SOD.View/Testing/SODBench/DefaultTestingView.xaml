<UserControl
    x:Class="SOD.View.Testing.SODBench.DefaultTestingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:SOD.View.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lc="clr-namespace:SOD.LocalizationService;assembly=SOD.LocalizationService"
    xmlns:local="clr-namespace:SOD.View.Testing.SODBench"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:oxy="http://oxyplot.org/wpf"
    xmlns:s="http://schemas.abtsoftware.co.uk/scichart"
    xmlns:sensorsVm="clr-namespace:SOD.ViewModels.Testing.SODBench.Sensors;assembly=SOD.ViewModels"
    d:DesignHeight="700"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="PressureAxisStyle" TargetType="{x:Type s:NumericAxis}">
            <Setter Property="MajorGridLineStyle">
                <Setter.Value>
                    <Style TargetType="Line">
                        <Setter Property="Stroke" Value="Gray" />
                        <Setter Property="Opacity" Value="1" />
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="TickTextBrush" Value="Black" />
        </Style>
        <Style x:Key="TimeAxisStyle" TargetType="{x:Type s:TimeSpanAxis}">
            <Setter Property="MajorGridLineStyle">
                <Setter.Value>
                    <Style TargetType="Line">
                        <Setter Property="Stroke" Value="Gray" />
                        <Setter Property="Opacity" Value="0.6" />
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="TickTextBrush" Value="Black" />
        </Style>
        <Style x:Key="TenzoAxisStyle" TargetType="{x:Type s:NumericAxis}">
            <Setter Property="MajorGridLineStyle">
                <Setter.Value>
                    <Style TargetType="Line">
                        <Setter Property="Stroke" Value="Gray" />
                        <Setter Property="Opacity" Value="1" />
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="TickTextBrush" Value="Black" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <StackPanel
            Grid.ColumnSpan="2"
            x:Name="topSp"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <materialDesign:Card Margin="2" Padding="5">
                <StackPanel Margin="5" VerticalAlignment="Center">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="16"
                        Opacity="0.6"
                        Text="{lc:Localization Testing.SODBench.ExposureTime}" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="30"
                        Text="{Binding ExposureTime}" />
                </StackPanel>
            </materialDesign:Card>

            <ItemsControl ItemsSource="{Binding Sensors}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>

                </ItemsControl.ItemsPanel>
                <ItemsControl.Resources>
                    <DataTemplate DataType="{x:Type sensorsVm:PressureSensorViewModel}">
                        <local:SensorView
                            MinHeight="90"
                            SensorName="{lc:Localization Testing.SODBench.Pressure}"
                            ViewModel="{Binding RelativeSource={RelativeSource Mode=Self}, Path=DataContext}" />
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type sensorsVm:TenzoSensorViewModel}">
                        <local:SensorView
                            MinHeight="90"
                            SensorName="{lc:Localization Testing.SODBench.Tenzo}"
                            ViewModel="{Binding RelativeSource={RelativeSource Mode=Self}, Path=DataContext}" />
                    </DataTemplate>
                </ItemsControl.Resources>
            </ItemsControl>
            <local:TemperatureSensorsView DataContext="{Binding TemperatureSensors}" ViewModel="{Binding RelativeSource={RelativeSource Mode=Self}, Path=DataContext}" />
        </StackPanel>
        <Grid Grid.Row="1" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <materialDesign:Card Margin="5" Padding="5">
                <s:SciChartSurface
                    x:Name="sciChartSurface"
                    Annotations="{s:AnnotationsBinding Annotations}"
                    Background="White"
                    DataContext="{Binding PressureChart}"
                    RenderableSeries="{s:SeriesBinding PressureSeries}"
                    XAxes="{s:AxesBinding XAxes}"
                    YAxes="{s:AxesBinding YAxes}">
                    <s:SciChartSurface.ChartModifier>
                        <s:ModifierGroup>
                            <s:LegendModifier ShowLegend="True"
                                ShowVisibilityCheckboxes="True"
                                ShowSeriesMarkers="True"
                                LegendPlacement="Inside"
                                Orientation="Vertical" />
                        </s:ModifierGroup>
                    </s:SciChartSurface.ChartModifier>
                </s:SciChartSurface>
            </materialDesign:Card>
        </Grid>
        <StackPanel 
            Grid.Row="2" 
            Orientation="Horizontal" 
            Background="White" 
            Margin="4"
            Opacity="0.9">
            <Button
                Width="100"
                Height="100"
                Margin="2"
                HorizontalAlignment="Left"
                Command="{Binding StartTest}">
                <Button.Style>
                    <Style BasedOn="{StaticResource MaterialDesignFlatButton}" TargetType="Button">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRunTest}" Value="False">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <StackPanel>
                                            <materialDesign:PackIcon
                                                Width="60"
                                                Height="60"
                                                HorizontalAlignment="Center"
                                                Kind="Play" />
                                            <TextBlock HorizontalAlignment="Center" Text="{lc:Localization Testing.SODBench.Start}" />
                                        </StackPanel>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsRunTest}" Value="True">
                                <Setter Property="Content">
                                    <Setter.Value>
                                        <StackPanel>
                                            <materialDesign:PackIcon
                                                Width="60"
                                                Height="60"
                                                HorizontalAlignment="Center"
                                                Kind="Stop" />
                                            <TextBlock HorizontalAlignment="Center" Text="{lc:Localization Testing.SODBench.Stop}" />
                                        </StackPanel>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button
                Height="100"
                Margin="2"
                HorizontalAlignment="Left"
                Command="{Binding Exposure}"
                Style="{StaticResource MaterialDesignFlatButton}">
                <StackPanel>
                    <materialDesign:PackIcon
                        Width="60"
                        Height="60"
                        HorizontalAlignment="Center"
                        Kind="Clock" />
                    <TextBlock HorizontalAlignment="Center" Text="{lc:Localization Testing.SODBench.Exposure}" />
                    <ProgressBar IsIndeterminate="True" Visibility="{Binding IsExposure, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>

            </Button>
            <Button
                Height="100"
                Margin="2"
                HorizontalAlignment="Left"
                Command="{Binding GoParameters}"
                Style="{StaticResource MaterialDesignFlatButton}">
                <StackPanel>
                    <materialDesign:PackIcon
                        Width="60"
                        Height="60"
                        HorizontalAlignment="Center"
                        Kind="PlaylistEdit" />
                    <TextBlock HorizontalAlignment="Center" Text="{lc:Localization Testing.SODBench.Parameters}" />
                </StackPanel>
            </Button>
            <Button
                Height="100"
                Margin="2"
                HorizontalAlignment="Left"
                Command="{Binding Result}"
                Style="{StaticResource MaterialDesignFlatButton}">
                <StackPanel>
                    <materialDesign:PackIcon
                        Width="60"
                        Height="60"
                        HorizontalAlignment="Center"
                        Kind="CheckboxMarkedOutline" />
                    <TextBlock HorizontalAlignment="Center" Text="{lc:Localization Testing.SODBench.Result}" />
                </StackPanel>
            </Button>
        </StackPanel>

        <materialDesign:Card
            Grid.Column="1"
            Grid.Row="2"
            MinWidth="500"
            Height="120"
            Margin="5"
            Padding="10">
            <TextBlock
                FontSize="16"
                HorizontalAlignment="Left"
                Text="{Binding InfoMessage, NotifyOnTargetUpdated=True}">
                <TextBlock.Triggers>
                    <EventTrigger RoutedEvent="Binding.TargetUpdated">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation
                                    Storyboard.TargetProperty="(TextBlock.Width)"
                                    From="0.0"
                                    To="2000.0"
                                    Duration="0:0:2.0" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TextBlock.Triggers>
            </TextBlock>
        </materialDesign:Card>
    </Grid>
</UserControl>
