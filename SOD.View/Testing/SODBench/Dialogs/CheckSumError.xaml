<UserControl
    x:Class="SOD.View.Testing.SODBench.Dialogs.CheckSumError"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:SOD.View.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lc="clr-namespace:SOD.LocalizationService;assembly=SOD.LocalizationService"
    xmlns:local="clr-namespace:SOD.View.Testing.SODBench.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="500"
    Height="300"
    mc:Ignorable="d">
    <controls:YesNoDialog
        NoCommand="{Binding No}"
        NoText="{lc:Localization Valves.No}"
        YesCommand="{Binding Yes}"
        YesText="{lc:Localization Valves.Yes}">
        <controls:YesNoDialog.MessageContent>
            <TextBlock
                Margin="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="24"
                Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                Text="{lc:Localization Testing.SODBench.CheckSumError}"
                TextWrapping="WrapWithOverflow" />
        </controls:YesNoDialog.MessageContent>
    </controls:YesNoDialog>
</UserControl>
