<UserControl
    x:Class="SOD.View.Testing.ManualCommandsBench.SelectVavleView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:SOD.View.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="700"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="40*" />
            <RowDefinition Height="50*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <controls:BackButton />
        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <Button
                Height="50"
                Command="{Binding SelectValve}"
                FontSize="24">
                Выбор арматуры
            </Button>
            <TextBlock
                Margin="0,10,0,0"
                HorizontalAlignment="Center"
                Opacity="0.5"
                Style="{StaticResource MaterialDesignSubtitle2TextBlock}">
                Арматура
            </TextBlock>
            <TextBlock FontSize="24" Text="{Binding Valve.Name}" />
        </StackPanel>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <StackPanel Margin="5">
                <TextBlock HorizontalAlignment="Center" Style="{StaticResource MaterialDesignHeadline6TextBlock}">Пост 1</TextBlock>
                <ComboBox
                    Margin="0,10"
                    materialDesign:HintAssist.Hint="Серийный номер"
                    FontSize="24"
                    IsEnabled="{Binding IsEnableFirstPost}"
                    ItemsSource="{Binding Serials}"
                    SelectedValue="{Binding FirstSerial}"
                    Style="{StaticResource MaterialDesignFloatingHintComboBox}" />
                <ToggleButton Height="50" IsChecked="{Binding IsEnableFirstPost, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="5">
                <TextBlock HorizontalAlignment="Center" Style="{StaticResource MaterialDesignHeadline6TextBlock}">Пост 2</TextBlock>
                <ComboBox
                    Margin="0,10"
                    materialDesign:HintAssist.Hint="Серийный номер"
                    FontSize="24"
                    IsEnabled="{Binding IsEnableSecondPost}"
                    ItemsSource="{Binding Serials}"
                    SelectedValue="{Binding SecondSerial}"
                    Style="{StaticResource MaterialDesignFloatingHintComboBox}" />
                <ToggleButton Height="50" IsChecked="{Binding IsEnableSecondPost, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Column="3" Margin="5">
                <TextBlock HorizontalAlignment="Center" Style="{StaticResource MaterialDesignHeadline6TextBlock}">Пост 3</TextBlock>
                <ComboBox
                    Margin="0,10"
                    materialDesign:HintAssist.Hint="Серийный номер"
                    FontSize="24"
                    IsEnabled="{Binding IsEnableThirdPost}"
                    ItemsSource="{Binding Serials}"
                    SelectedValue="{Binding ThirdSerial}"
                    Style="{StaticResource MaterialDesignFloatingHintComboBox}" />
                <ToggleButton Height="50" IsChecked="{Binding IsEnableThirdPost, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
