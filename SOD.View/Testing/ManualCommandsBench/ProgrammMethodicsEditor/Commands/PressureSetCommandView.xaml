<UserControl
    x:Class="SOD.View.Testing.ManualCommandsBench.ProgrammMethodicsEditor.Commands.PressureSetCommandView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SOD.View.Testing.ManualCommandsBench.ProgrammMethodicsEditor.Commands"
    xmlns:lc="clr-namespace:SOD.LocalizationService;assembly=SOD.LocalizationService"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="400"
    mc:Ignorable="d">
    <Grid>
        <StackPanel HorizontalAlignment="Center">
            <TextBlock 
                FontSize="24"
                Text="{lc:Localization Testing.ManualCommandsBench.PressureSet}" />
            <StackPanel
                Margin="0,20,0,0"
                HorizontalAlignment="Center"
                Orientation="Horizontal">
                <ToggleButton
                    Width="50"
                    Height="50"
                    Margin="10,4,10,4"
                    Content="A"
                    FontSize="24"
                    IsChecked="{Binding CavityA}"
                    Style="{StaticResource MaterialDesignFlatToggleButton}" />
                <ToggleButton
                    Width="50"
                    Height="50"
                    Margin="10,4,10,4"
                    Content="B"
                    FontSize="24"
                    IsChecked="{Binding CavityB}"
                    Style="{StaticResource MaterialDesignFlatToggleButton}" />
                <ToggleButton
                    Width="50"
                    Height="50"
                    Margin="10,4,10,4"
                    Content="C"
                    FontSize="24"
                    IsChecked="{Binding CavityC}"
                    Style="{StaticResource MaterialDesignFlatToggleButton}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
