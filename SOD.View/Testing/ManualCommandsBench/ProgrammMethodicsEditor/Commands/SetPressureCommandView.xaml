<UserControl
    x:Class="SOD.View.Testing.ManualCommandsBench.ProgrammMethodicsEditor.Commands.SetPressureCommandView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SOD.View.Testing.ManualCommandsBench.ProgrammMethodicsEditor.Commands"
    xmlns:lc="clr-namespace:SOD.LocalizationService;assembly=SOD.LocalizationService"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="400"
    mc:Ignorable="d">
    <Grid>
        <StackPanel>
            <TextBlock 
                HorizontalAlignment="Center" 
                FontSize="24"
                Text="{lc:Localization Testing.ManualCommandsBench.SetPressure}" />
            <TextBox
                Margin="10"
                materialDesign:HintAssist.Hint="{lc:Localization Testing.ManualCommandsBench.PressureOrFormula}"
                FontSize="24"
                Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                Text="{Binding Pressure, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock 
                Margin="10,0,0,0" 
                Style="{StaticResource MaterialDesignCaptionTextBlock}"
                Text="{lc:Localization Testing.ManualCommandsBench.Example}" />
        </StackPanel>

    </Grid>
</UserControl>
