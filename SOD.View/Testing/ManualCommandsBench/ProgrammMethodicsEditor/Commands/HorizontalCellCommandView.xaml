<UserControl
    x:Class="SOD.View.Testing.ManualCommandsBench.ProgrammMethodicsEditor.Commands.HorizontalCellCommandView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SOD.View.Testing.ManualCommandsBench.ProgrammMethodicsEditor.Commands"
    xmlns:lc="clr-namespace:SOD.LocalizationService;assembly=SOD.LocalizationService"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="300"
    mc:Ignorable="d">
    <Grid>
        <StackPanel HorizontalAlignment="Center">
            <TextBlock 
                FontSize="24"
                HorizontalAlignment="Center"
                Text="{lc:Localization Testing.ManualCommandsBench.HorizontalCell}" />
            <UniformGrid Margin="10" >
                <RadioButton
                    Margin="15"
                    Content="{lc:Localization MediumType3Post.Water}"
                    IsChecked="{Binding Liquid}"
                    Style="{StaticResource MaterialDesignTabRadioButton}" />
                <RadioButton
                    Content="{lc:Localization MediumType3Post.WaterHigh}"
                    IsChecked="{Binding LiquidHigh}"
                    Style="{StaticResource MaterialDesignTabRadioButton}" />
                <RadioButton
                    Content="{lc:Localization MediumType3Post.Air}"
                    IsChecked="{Binding Gas}"
                    Style="{StaticResource MaterialDesignTabRadioButton}" />
                <RadioButton
                    Content="{lc:Localization MediumType3Post.AirHigh}"
                    IsChecked="{Binding GasHigh}"
                    Style="{StaticResource MaterialDesignTabRadioButton}" />
            </UniformGrid>
        </StackPanel>
    </Grid>
</UserControl>
