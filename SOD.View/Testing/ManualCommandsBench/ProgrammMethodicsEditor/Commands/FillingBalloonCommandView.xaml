<UserControl
    x:Class="SOD.View.Testing.ManualCommandsBench.ProgrammMethodicsEditor.Commands.FillingBalloonCommandView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SOD.View.Testing.ManualCommandsBench.ProgrammMethodicsEditor.Commands"
    xmlns:lc="clr-namespace:SOD.LocalizationService;assembly=SOD.LocalizationService"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="400"
    mc:Ignorable="d">
    <Grid>
        <StackPanel>
            <TextBlock 
                HorizontalAlignment="Center" 
                FontSize="24"
                Text="{lc:Localization Testing.ManualCommandsBench.FillingBalloon}" />
            <StackPanel Margin="10" Orientation="Horizontal">
                <TextBlock 
                    Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                    Text="{lc:Localization Testing.ManualCommandsBench.FillingTimeValve}" />
                <ToggleButton Margin="10,0,0,0" IsChecked="{Binding IsValveTime}" />
            </StackPanel>
            <StackPanel Margin="10" Orientation="Horizontal">
                <TextBlock 
                    Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                    Text="{lc:Localization Testing.ManualCommandsBench.FillingTimeManual}" />
                <ToggleButton Margin="10,0,0,0" IsChecked="{Binding IsManual}" />
            </StackPanel>
            <TextBox
                Margin="10"
                materialDesign:HintAssist.Hint="{lc:Localization Testing.ManualCommandsBench.FillTimeSeconds}"
                FontSize="24"
                Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                Text="{Binding Time, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Visibility="{Binding IsManual, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </StackPanel>
    </Grid>
</UserControl>
