<UserControl
    x:Class="SOD.View.Testing.ManualCommandsBench.ProgrammMethodicsEditor.EditProgrammMethodicsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:commands="clr-namespace:SOD.View.Testing.ManualCommandsBench.ProgrammMethodicsEditor.Commands"
    xmlns:commandsVM="clr-namespace:SOD.ViewModels.Testing.ManualCommandsBench.ProgrammMethodicsEditor.Commands;assembly=SOD.ViewModels"
    xmlns:controls="clr-namespace:SOD.View.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SOD.View.Testing.ManualCommandsBench.ProgrammMethodicsEditor"
    xmlns:lc="clr-namespace:SOD.LocalizationService;assembly=SOD.LocalizationService"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tests="clr-namespace:SOD.View.Testing.ManualCommandsBench.ProgrammMethodicsEditor.Tests"
    xmlns:testsVM="clr-namespace:SOD.ViewModels.Testing.ManualCommandsBench.ProgrammMethodicsEditor.Tests;assembly=SOD.ViewModels"
    xmlns:viewModels="clr-namespace:SOD.ViewModels.Testing.ManualCommandsBench.ProgrammMethodicsEditor;assembly=SOD.ViewModels"
    d:DesignHeight="600"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal">
            <controls:BackButton />
            <controls:SaveButton />
        </StackPanel>
        <Grid Grid.Row="1">
            <TextBox
                Margin="5"
                materialDesign:HintAssist.Hint="{lc:Localization Testing.ManualCommandsBench.Name}"
                FontSize="24"
                Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button
                        Height="50"
                        Margin="10,0,0,0"
                        Command="{Binding AddCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="24"
                                Height="24"
                                Kind="Add" />
                            <TextBlock 
                                VerticalAlignment="Center"
                                Text="{lc:Localization Testing.ManualCommandsBench.Command}"/>
                        </StackPanel>
                    </Button>
                    <Button
                        Height="50"
                        Margin="10,0,0,0"
                        Command="{Binding Delete}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="24"
                                Height="24"
                                Kind="Garbage" />
                            <TextBlock 
                                VerticalAlignment="Center"
                                Text="{lc:Localization Testing.ManualCommandsBench.Delete}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <TreeView
                    Grid.Row="1"
                    Margin="10"
                    FontSize="16"
                    ItemsSource="{Binding Childrens}"
                    SelectedItemChanged="TreeView_SelectedItemChanged">
                    
                    <!--Для разворачивания всех элементов дерева--> 
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource MaterialDesignTreeViewItem}">
                            <Setter Property="TreeViewItem.IsExpanded" Value="True"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    
                    <TreeView.Resources>
                        <DataTemplate DataType="{x:Type commandsVM:BaseCommandViewModel}">
                            <StackPanel Orientation="Horizontal">
                                <Image Width="20" Height="20">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CanSave}" Value="False">
                                                    <Setter Property="Source" Value="{StaticResource ErrorIcon}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding CanSave}" Value="True">
                                                    <Setter Property="Source" Value="{x:Null}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Margin="5,0,0,0" Text="{Binding Name}" />
                            </StackPanel>

                        </DataTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type testsVM:TestingViewModel}" ItemsSource="{Binding Childrens}">
                            <StackPanel Orientation="Horizontal">
                                <Image Width="20" Height="20">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CanSave}" Value="False">
                                                    <Setter Property="Source" Value="{StaticResource ErrorIcon}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding CanSave}" Value="True">
                                                    <Setter Property="Source" Value="{x:Null}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <TextBlock Margin="5,0,0,0" Text="{Binding Name}" />
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                </TreeView>
            </Grid>
            <materialDesign:Card
                Grid.Column="1"
                Margin="10"
                Padding="10">

                <ContentPresenter Content="{Binding SelectedCommand}">
                    <ContentPresenter.Resources>
                        <DataTemplate DataType="{x:Type commandsVM:TestMediumCommandViewModel}">
                            <commands:TestMediumCommandView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type commandsVM:FillingCommandViewModel}">
                            <commands:FillingCommandView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type commandsVM:PressurizeCavityCommandViewModel}">
                            <commands:PressurizeCavityCommandView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type commandsVM:LeakControlCavityCommandViewModel}">
                            <commands:LeakControlCavityCommandView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type commandsVM:SetPressureCommandViewModel}">
                            <commands:SetPressureCommandView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type commandsVM:HoldCommandViewModel}">
                            <commands:HoldCommandView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type commandsVM:RegistrationCommandViewModel}">
                            <commands:RegistrationCommandView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type commandsVM:PressureRealeseCommandViewModel}">
                            <commands:PressureRealeseCommandView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type commandsVM:PurgeCommandViewModel}">
                            <commands:PurgeCommandView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type testsVM:TestingViewModel}">
                            <tests:TestingView />
                        </DataTemplate>
                    </ContentPresenter.Resources>
                </ContentPresenter>
            </materialDesign:Card>


        </Grid>

    </Grid>
</UserControl>
