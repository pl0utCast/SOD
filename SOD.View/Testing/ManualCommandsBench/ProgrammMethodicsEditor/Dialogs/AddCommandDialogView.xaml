<UserControl
    x:Class="SOD.View.Testing.ManualCommandsBench.ProgrammMethodicsEditor.Dialogs.AddCommandDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:SOD.View.Controls"
    xmlns:converters="clr-namespace:SOD.View.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lc="clr-namespace:SOD.LocalizationService;assembly=SOD.LocalizationService"
    xmlns:local="clr-namespace:SOD.View.Testing.ManualCommandsBench.ProgrammMethodicsEditor.Dialogs"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="150"
    d:DesignWidth="400"
    mc:Ignorable="d">
    <controls:YesNoDialog 
        NoCommand="{Binding Cancel}" 
        NoText="{lc:Localization Props.EditPropertyView.Cancel}"
        YesCommand="{Binding Save}"
        YesText="{lc:Localization Props.EditPropertyView.Save}">
        <controls:YesNoDialog.MessageContent>
            <ComboBox
                Margin="10"
                materialDesign:HintAssist.Hint="{lc:Localization Testing.ManualCommandsBench.Command}"
                FontSize="24"
                ItemsSource="{Binding Source={converters:CommandTypeConverter}, Path=Types}"
                SelectedValue="{Binding SelectedCommand, Converter={converters:CommandTypeConverter}}"
                Style="{StaticResource MaterialDesignFloatingHintComboBox}" />
        </controls:YesNoDialog.MessageContent>
    </controls:YesNoDialog>
</UserControl>
