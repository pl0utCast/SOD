<UserControl
    x:Class="SOD.View.Testing.ManualCommandsBench.SelectProgrammMethodicsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:System="clr-namespace:System;assembly=mscorlib"
    xmlns:controls="clr-namespace:SOD.View.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lc="clr-namespace:SOD.LocalizationService;assembly=SOD.LocalizationService"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prorammMethodicsVM="clr-namespace:SOD.ViewModels.Testing.ManualCommandsBench;assembly=SOD.ViewModels"
    d:DesignHeight="600"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60*" />
                <ColumnDefinition Width="40*" />
            </Grid.ColumnDefinitions>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Button
                        Height="50"
                        Margin="10,0,0,0"
                        Command="{Binding Add}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="24"
                                Height="24"
                                Kind="Add" />
                            <TextBlock 
                                Text="{lc:Localization Testing.ManualCommandsBench.Add}"
                                VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button
                        Height="50"
                        Margin="10,0,0,0"
                        Command="{Binding Delete}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="24"
                                Height="24"
                                Kind="Garbage" />
                            <TextBlock 
                                Text="{lc:Localization Testing.ManualCommandsBench.Delete}"
                                VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <ListView
                    Name="ListView"
                    Grid.Row="1"
                    Margin="5"
                    HorizontalAlignment="Stretch"
                    ItemsSource="{Binding ProgrammMethodics}"
                    SelectedItem="{Binding SelectedProgrammMethodics}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                x:Name="Border"
                                Padding="3"
                                BorderBrush="{DynamicResource MaterialDesignDivider}"
                                BorderThickness="0,0,0,1">
                                <StackPanel MinWidth="415">
                                    <TextBlock Style="{StaticResource MaterialDesignBody2TextBlock}" Text="{Binding Name}" />
                                    <TextBlock Style="{StaticResource MaterialDesignBody2TextBlock}" Text="{Binding ValveTypeName}" />
                                    <TextBlock Style="{StaticResource MaterialDesignBody2TextBlock}" Text="{Binding CreatedDate}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
            <Grid Grid.Column="1">
                <ContentPresenter Content="{Binding SelectedProgrammMethodics}">
                    <ContentPresenter.Resources>
                        <DataTemplate DataType="{x:Type prorammMethodicsVM:ProgrammMethodicsInfoViewModel}">
                            <materialDesign:Card Margin="10" Padding="10" Background="{DynamicResource MaterialDesignCardBackground}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition Width="auto" />
                                    </Grid.ColumnDefinitions>

                                    <ItemsControl ItemsSource="{Binding FullInfo}">
                                        <ItemsControl.Resources>
                                            <DataTemplate DataType="{x:Type prorammMethodicsVM:TestInfoViewModel}">
                                                <StackPanel Margin="0,2">
                                                    <StackPanel.Resources>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                                                        </Style>
                                                    </StackPanel.Resources>
                                                    <TextBlock Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Text="{Binding TestName}"/>
                                                    <TextBlock Style="{StaticResource MaterialDesignSubtitle2TextBlock}" Text="{Binding StandartName}" />
                                                    <ItemsControl Margin="20,0,0,0" ItemsSource="{Binding Commands}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Style="{StaticResource MaterialDesignTextBlock}" Text="{Binding}" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </DataTemplate>
                                            <DataTemplate DataType="{x:Type System:String}">
                                                <TextBlock Style="{StaticResource MaterialDesignTextBlock}" Text="{Binding}" />
                                            </DataTemplate>
                                        </ItemsControl.Resources>
                                    </ItemsControl>
                                    <controls:EditFlatButton
                                        Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top" />
                                </Grid>
                            </materialDesign:Card>
                        </DataTemplate>
                    </ContentPresenter.Resources>
                </ContentPresenter>

            </Grid>
        </Grid>

    </Grid>
</UserControl>
