<UserControl
    x:Class="SOD.View.Testing.ManualCommandsBench.Test.PostView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SOD.View.Testing.ManualCommandsBench.Test"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style
            x:Key="TextBlockValue"
            BasedOn="{StaticResource MaterialDesignTextBlock}"
            TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="Margin" Value="5,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style
            x:Key="TextBlockUnit"
            BasedOn="{StaticResource MaterialDesignTextBlock}"
            TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Margin" Value="0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition Width="auto" />
        </Grid.ColumnDefinitions>
        <TextBlock
            Grid.ColumnSpan="4"
            HorizontalAlignment="Center"
            FontSize="18"
            Text="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:PostView}, Mode=FindAncestor}, Path=Title}" />
        <TextBlock Grid.Row="1" FontSize="24">A</TextBlock>
        <TextBlock Grid.Row="2" FontSize="24">B</TextBlock>
        <TextBlock Grid.Row="3" FontSize="24">C</TextBlock>
        <!--  Pressure A  -->
        <StackPanel
            Grid.Row="1"
            Grid.Column="1"
            Orientation="Horizontal">
            <TextBlock Style="{StaticResource TextBlockValue}" Text="{Binding PressureA}" />
            <TextBlock Style="{StaticResource TextBlockUnit}" Text="{Binding PressureAUnit}" />
        </StackPanel>
        <!--  Pressure B  -->
        <StackPanel
            Grid.Row="2"
            Grid.Column="1"
            Orientation="Horizontal">
            <TextBlock Style="{StaticResource TextBlockValue}" Text="{Binding PressureB}" />
            <TextBlock Style="{StaticResource TextBlockUnit}" Text="{Binding PressureBUnit}" />
        </StackPanel>
        <!--  Pressure C  -->
        <StackPanel
            Grid.Row="3"
            Grid.Column="1"
            Orientation="Horizontal">
            <TextBlock Style="{StaticResource TextBlockValue}" Text="{Binding PressureC}" />
            <TextBlock Style="{StaticResource TextBlockUnit}" Text="{Binding PressureCUnit}" />
        </StackPanel>
        <!--  Leakage A  -->
        <StackPanel
            Grid.Row="1"
            Grid.Column="2"
            Orientation="Horizontal">
            <TextBlock Style="{StaticResource TextBlockValue}" Text="{Binding LeakageA}" />
            <TextBlock Style="{StaticResource TextBlockUnit}" Text="{Binding LeakageAUnit}" />
        </StackPanel>
        <!--  Leakage B  -->
        <StackPanel
            Grid.Row="2"
            Grid.Column="2"
            Orientation="Horizontal">
            <TextBlock Style="{StaticResource TextBlockValue}" Text="{Binding LeakageB}" />
            <TextBlock Style="{StaticResource TextBlockUnit}" Text="{Binding LeakageBUnit}" />
        </StackPanel>
        <!--  Leakage C  -->
        <StackPanel
            Grid.Row="3"
            Grid.Column="2"
            Orientation="Horizontal">
            <TextBlock Style="{StaticResource TextBlockValue}" Text="{Binding LeakageC}" />
            <TextBlock Style="{StaticResource TextBlockUnit}" Text="{Binding LeakageCUnit}" />
        </StackPanel>
        <Border
            Grid.RowSpan="4"
            Grid.Column="3"
            Margin="5,10,-12,0"
            Padding="3"
            BorderBrush="{DynamicResource MaterialDesignDivider}"
            BorderThickness="1,0,0,0" />
