<UserControl
    x:Class="SOD.View.Testing.ManualCommandsBench.Test.TestView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:commands="clr-namespace:SOD.View.Testing.ManualCommandsBench.Test.Commands"
    xmlns:controls="clr-namespace:SOD.View.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SOD.View.Testing.ManualCommandsBench.Test"
    xmlns:lc="clr-namespace:SOD.LocalizationService;assembly=SOD.LocalizationService"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:oxy="http://oxyplot.org/wpf"
    xmlns:s="http://schemas.abtsoftware.co.uk/scichart"
    d:DesignHeight="700"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <ItemsControl ItemsSource="{Binding Posts}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="{Binding PostsColumn}" />
                </ItemsPanelTemplate>

            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <local:PostView Title="{Binding Name}" Margin="5,0" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <materialDesign:Card Grid.Row="1" Margin="5" Padding="5">
            <s:SciChartSurface
                    x:Name="sciChartSurface"
                    Annotations="{s:AnnotationsBinding Annotations}"
                    Background="White"
                    DataContext="{Binding PressureChart}"
                    RenderableSeries="{s:SeriesBinding Series}"
                    XAxes="{s:AxesBinding XAxes}"
                    YAxes="{s:AxesBinding YAxes}" />
        </materialDesign:Card>

        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Button
                Width="100"
                Height="80"
                HorizontalAlignment="Left"
                Command="{Binding Run}"
                Style="{StaticResource MaterialDesignFlatButton}">
                <materialDesign:PackIcon Width="60" Height="60">
                    <materialDesign:PackIcon.Style>
                        <Style TargetType="materialDesign:PackIcon">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsTestRun}" Value="True">
                                    <Setter Property="Kind" Value="Stop" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsTestRun}" Value="False">
                                    <Setter Property="Kind" Value="Play" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </materialDesign:PackIcon.Style>
                </materialDesign:PackIcon>
            </Button>
            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <commands:CommandView DataContext="{Binding Commands}" />
                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <Button
                        Height="80"
                        HorizontalAlignment="Left"
                        Command="{Binding SelectProgramm}"
                        Style="{StaticResource MaterialDesignFlatButton}">
                        <StackPanel>
                            <materialDesign:PackIcon
                                Width="30"
                                Height="30"
                                HorizontalAlignment="Center"
                                Kind="FormatListText" />
                            <TextBlock 
                                Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                Text="{lc:Localization Settings.Bench.SODBenchSettingsView.Parameters}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

        </Grid>
    </Grid>
</UserControl>
