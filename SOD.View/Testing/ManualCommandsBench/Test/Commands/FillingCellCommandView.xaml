<UserControl
    x:Class="SOD.View.Testing.ManualCommandsBench.Test.Commands.FillingCellCommandView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SOD.View.Testing.ManualCommandsBench.Test.Commands"
    xmlns:lc="clr-namespace:SOD.LocalizationService;assembly=SOD.LocalizationService"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <StackPanel>
        <TextBlock 
            Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
            Text="{lc:Localization Testing.ManualCommandsBench.FillingCell}" />
        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
            <TextBlock
                Text="{lc:Localization Testing.ManualCommandsBench.SelectedCavity}"></TextBlock>
            <TextBlock Margin="10,0,0,0" Text="{Binding Cavity}" />
        </StackPanel>
    </StackPanel>
</UserControl>
