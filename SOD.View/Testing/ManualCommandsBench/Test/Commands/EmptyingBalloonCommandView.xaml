<UserControl
    x:Class="SOD.View.Testing.ManualCommandsBench.Test.Commands.EmptyingBalloonCommandView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SOD.View.Testing.ManualCommandsBench.Test.Commands"
    xmlns:lc="clr-namespace:SOD.LocalizationService;assembly=SOD.LocalizationService"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <StackPanel>
        <TextBlock 
            Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
            Text="{lc:Localization Testing.ManualCommandsBench.EmptyingBalloon}" />
        <TextBlock
            HorizontalAlignment="Center"
            Style="{StaticResource MaterialDesignHeadline6TextBlock}"
            Text="{Binding Time}" />
    </StackPanel>
</UserControl>
