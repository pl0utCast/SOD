<UserControl
    x:Class="SOD.View.Testing.ManualCommandsBench.Test.Commands.PurgeCommandView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conveters="clr-namespace:SOD.View.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SOD.View.Testing.ManualCommandsBench.Test.Commands"
    xmlns:lc="clr-namespace:SOD.LocalizationService;assembly=SOD.LocalizationService"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <StackPanel>
        <TextBlock 
            Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
            Text="{lc:Localization Testing.ManualCommandsBench.Purge}" />
        <TextBlock Style="{StaticResource MaterialDesignHeadline5TextBlock}" Text="{Binding Medium, Converter={conveters:MediumTypeConverter3Post}}" />
    </StackPanel>
</UserControl>
