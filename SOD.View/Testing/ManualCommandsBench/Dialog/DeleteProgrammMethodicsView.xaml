<UserControl
    x:Class="SOD.View.Testing.ManualCommandsBench.Dialog.DeleteProgrammMethodicsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:SOD.View.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SOD.View.Testing.ManualCommandsBench.Dialog"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:lc="clr-namespace:SOD.LocalizationService;assembly=SOD.LocalizationService"
    MinWidth="500"
    MinHeight="200"
    mc:Ignorable="d">
    <controls:YesNoDialog
        NoCommand="{Binding Cancel}"
        NoText="{lc:Localization Settings.DeviceAndSensor.Device.No}"
        YesCommand="{Binding Delete}"
        YesText="{lc:Localization Settings.DeviceAndSensor.Device.Yes}">
        <controls:YesNoDialog.MessageContent>
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="24">
                Вы действительно хотите удалить ?
            </TextBlock>
        </controls:YesNoDialog.MessageContent>
    </controls:YesNoDialog>
</UserControl>
