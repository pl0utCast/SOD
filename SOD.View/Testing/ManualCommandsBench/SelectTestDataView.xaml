<UserControl
    x:Class="SOD.View.Testing.ManualCommandsBench.SelectTestDataView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:SOD.View.Controls"
    xmlns:controlsVM="clr-namespace:SOD.ViewModels.Controls;assembly=SOD.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SOD.View.Testing.ManualCommandsBench"
    xmlns:lc="clr-namespace:SOD.LocalizationService;assembly=SOD.LocalizationService"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <controls:CustomScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <ItemsControl ItemsSource="{Binding Posts}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{Binding PostsColumn}" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="5,10,-12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock HorizontalAlignment="Center" FontSize="16" Text="{Binding Name}" />
                                <ComboBox
                                    materialDesign:HintAssist.Hint="{lc:Localization Testing.ManualCommandsBench.SerialNumber}"
                                    FontSize="24"
                                    ItemsSource="{Binding Serials}"
                                    SelectedValue="{Binding Serial}"
                                    Style="{StaticResource MaterialDesignFloatingHintComboBox}" />
                                <ToggleButton Height="60" IsChecked="{Binding IsEnable, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                            </StackPanel>
                            <Border
                                Grid.Column="1"
                                Margin="5"
                                Padding="3"
                                BorderBrush="{DynamicResource MaterialDesignDivider}"
                                BorderThickness="1,0,0,0" />
                        </Grid>

                    </DataTemplate>

                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.ColumnSpan="2"
                    Margin="10"
                    FontSize="24"
                    Text="{lc:Localization Testing.ManualCommandsBench.Units}" />
                <StackPanel Grid.Row="1" Margin="10,0,0,0">
                    <TextBlock 
                        FontSize="20" 
                        Text="{lc:Localization Testing.ManualCommandsBench.Pressure}"/> 
                    <ListBox ItemsSource="{Binding PressureUnits}" SelectedValue="{Binding SelectedPressureUnit}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox
                                    Content="{Binding Name}"
                                    FontSize="20"
                                    IsChecked="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListBoxItem}, Path=IsSelected}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1">
                    <TextBlock 
                        FontSize="20"
                        Text="{lc:Localization Testing.ManualCommandsBench.Leakage}"/>
                    <ListBox ItemsSource="{Binding LeakageUnits}" SelectedValue="{Binding SelectedLeakageUnit}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox
                                    Content="{Binding Name}"
                                    FontSize="20"
                                    IsChecked="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListBoxItem}, Path=IsSelected}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Grid>
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <TextBlock
                    Margin="10"
                    FontSize="24"
                    Text="{lc:Localization Testing.ManualCommandsBench.Parameters}" />
                <ItemsControl Grid.Row="1" ItemsSource="{Binding Properties}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.Resources>
                        <DataTemplate DataType="{x:Type controlsVM:UnitValueViewModel}">
                            <controls:UnitValueView
                                Margin="10"
                                VerticalAlignment="Top"
                                FieldName="{Binding Name}" />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type controlsVM:PressureClassViewModel}">
                            <controls:NamedComboBox
                                Margin="10"
                                VerticalAlignment="Top"
                                FieldName="{Binding Name}" />

                        </DataTemplate>
                        <DataTemplate DataType="{x:Type controlsVM:NpsViewModel}">
                            <controls:NamedComboBox
                                Margin="10"
                                VerticalAlignment="Top"
                                FieldName="{Binding Name}" />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type controlsVM:StringValueViewModel}">
                            <controls:SimpleValueView
                                Margin="10"
                                VerticalAlignment="Top"
                                FieldName="{Binding Name}" />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type controlsVM:DoubleValueViewModel}">
                            <controls:SimpleValueView
                                Margin="10"
                                VerticalAlignment="Top"
                                FieldName="{Binding Name}" />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type controlsVM:IntegerValueViewModel}">
                            <controls:SimpleValueView
                                Margin="10"
                                VerticalAlignment="Top"
                                FieldName="{Binding Name}" />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type controlsVM:EditableComboBoxViewModel}">
                            <controls:EditableComboBox
                                Margin="10"
                                VerticalAlignment="Top"
                                Hint="{Binding Name}"
                                ItemsSource="{Binding Items}"
                                Selected="{Binding SelectedValue, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                        </DataTemplate>
                    </ItemsControl.Resources>
                </ItemsControl>
            </Grid>
        </Grid>
    </controls:CustomScrollViewer>

</UserControl>
