<UserControl
    x:Class="SOD.View.Testing.PressureChartView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SOD.View.Testing"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:s="http://schemas.abtsoftware.co.uk/scichart"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <s:SciChartSurface
        x:Name="sciChart"
        Grid.Column="1"
        Padding="0"
        Annotations="{s:AnnotationsBinding AnnotationViewModels}"
        Background="Transparent"
        RenderableSeries="{s:SeriesBinding RenderableSeries}"
        XAxes="{s:AxesBinding XAxes}"
        YAxes="{s:AxesBinding YAxes}" />
</UserControl>
