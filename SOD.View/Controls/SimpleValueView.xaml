<UserControl
    x:Class="SOD.View.Controls.SimpleValueView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SOD.View.Controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid>
        <TextBox
            materialDesign:HintAssist.Hint="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:SimpleValueView}}, Path=FieldName}"
            FontSize="24"
            Style="{StaticResource MaterialDesignFloatingHintTextBox}"
            Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
    </Grid>
</UserControl>
