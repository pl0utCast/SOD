<UserControl
    x:Class="SOD.View.Controls.UnitSelector"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:SOD.View.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:SOD.View.Controls"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ComboBox
        HorizontalAlignment="Stretch"
        VerticalAlignment="Bottom"
        materialDesign:HintAssist.Hint="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:UnitSelector}, Path=Title}"
        FontSize="24"
        ItemsSource="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type local:UnitSelector}}, Path=Types}"
        SelectedValue="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type local:UnitSelector}}, Path=Type, UpdateSourceTrigger=PropertyChanged}"
        Style="{StaticResource MaterialDesignFloatingHintComboBox}">
        <ComboBox.ItemTemplate>
            <DataTemplate>
                <TextBlock FontSize="24" Text="{Binding Name}" />
            </DataTemplate>
        </ComboBox.ItemTemplate>
    </ComboBox>
</UserControl>
