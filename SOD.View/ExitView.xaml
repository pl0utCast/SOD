<UserControl
    x:Class="SOD.View.ExitView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lc="clr-namespace:SOD.LocalizationService;assembly=SOD.LocalizationService"
    xmlns:local="clr-namespace:SOD.View"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel.Resources>
            <Style BasedOn="{StaticResource MaterialDesignRaisedButton}" TargetType="Button">
                <Setter Property="Margin" Value="10" />
                <Setter Property="FontSize" Value="24" />
                <Setter Property="Height" Value="50" />
                <Setter Property="MinWidth" Value="500" />
            </Style>
        </StackPanel.Resources>
        <Button Command="{Binding Reset}" Content="{lc:Localization Exit.Reset}" />
        <Button Command="{Binding ShoutDown}" Content="{lc:Localization Exit.Shutdown}" />
        <Button Command="{Binding Exit}" Content="{lc:Localization Exit.Exit}" />
    </StackPanel>
</UserControl>
